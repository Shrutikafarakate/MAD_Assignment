<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E3F2FD">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="60dp">

        <!-- Profile Image -->
        <ImageView
            android:id="@+id/profileImage"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="center"
            android:src="@drawable/photo"
            android:scaleType="centerCrop"
            android:background="@drawable/circle_bg"
            android:padding="5dp"
            android:layout_marginBottom="15dp" />

        <!-- Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shrutika Farakate"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#0D47A1"
            android:layout_gravity="center"
            android:layout_marginBottom="5dp"/>

        <!-- Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📧 shrutikafarakate9982@gmail.com"
            android:textSize="16sp"
            android:textColor="#37474F"
            android:layout_marginBottom="5dp"/>

        <!-- Mobile -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📱 9373820893"
            android:textSize="16sp"
            android:textColor="#37474F"
            android:layout_marginBottom="15dp"/>

        <!-- Education Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#BBDEFB"
            android:padding="15dp"
            android:layout_marginBottom="15dp"
            android:backgroundTint="#BBDEFB"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎓 Education"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BTech in Computer Science\nCGPA: 9.4/10"
                android:textSize="16sp"
                android:textColor="#000000"
                android:layout_marginTop="5dp"/>
        </LinearLayout>

        <!-- Skills Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#C8E6C9"
            android:padding="15dp"
            android:layout_marginBottom="15dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💻 Skills"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="C, C++, Java, Python, Go\nHTML, CSS, JavaScript\nMySQL, Git, Flutter"
                android:textSize="16sp"
                android:textColor="#000000"
                android:layout_marginTop="5dp"/>
        </LinearLayout>

        <!-- Projects Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFE0B2"
            android:padding="15dp"
            android:layout_marginBottom="20dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚀 Projects"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#E65100"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• URL Shortener Web App\n• Task Manager CLI (Go)\n• Online Bakery Website"
                android:textSize="16sp"
                android:textColor="#000000"
                android:layout_marginTop="5dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>